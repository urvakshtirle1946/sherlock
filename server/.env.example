PORT=4000
MONGODB_URI=mongodb://localhost:27017/sherlock

# Optional: enables Whisper transcription + GPT prose explanations
# Without this key, the system still runs; transcript/explanation signals are disabled
OPENAI_API_KEY=sk-...
NVIDIA_API_KEY=nvapi-...

# CORS origin for the Next.js frontend
CLIENT_URL=http://localhost:3000

# Upload directory (relative to /server)
UPLOAD_DIR=uploads
