PORT=4000
MONGODB_URI=mongodb://localhost:27017/sherlock

# Optional: enables Whisper transcription + GPT prose explanations
# Without this key, the system still runs; transcript/explanation signals are disabled
OPENAI_API_KEY=sk-...
NVIDIA_API_KEY=nvapi-...

# Recall.ai Integration for live meeting proctoring
RECALLAI_API_KEY=...
RECALLAI_REGION=us-west-2

# Webhook Callback Host (Must be public, e.g. localtunnel URL or deployed URL. Recall.ai blocks localhost URLs)
HOST_URL=https://your-localtunnel-subdomain.loca.lt

# CORS origin for the Next.js frontend
CLIENT_URL=http://localhost:3000

# Upload directory (relative to /server)
UPLOAD_DIR=uploads
